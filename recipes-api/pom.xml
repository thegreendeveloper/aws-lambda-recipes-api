<?xml version="1.0" encoding="UTF-8"?>
<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.recipes</groupId>
        <artifactId>recipes-api</artifactId>
        <version>1.0.0</version>
    </parent>

    <artifactId>recipes-api-rest</artifactId>
    <name>recipes-api</name>
    <description>API layer — REST controllers, Lambda handler, OpenAPI spec. Produces the deployable fat JAR.
    </description>

    <dependencies>
        <!-- Internal: service layer (repository arrives transitively) -->
        <dependency>
            <groupId>com.recipes</groupId>
            <artifactId>recipes-service</artifactId>
        </dependency>

        <!-- Spring Boot Web (Tomcat excluded for Lambda) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
            <exclusions>
                <exclusion>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-starter-tomcat</artifactId>
                </exclusion>
            </exclusions>
        </dependency>

        <!-- AWS Serverless Java Container -->
        <dependency>
            <groupId>com.amazonaws.serverless</groupId>
            <artifactId>aws-serverless-java-container-springboot3</artifactId>
            <version>${aws-serverless-container.version}</version>
        </dependency>

        <!-- AWS Lambda Core -->
        <dependency>
            <groupId>com.amazonaws</groupId>
            <artifactId>aws-lambda-java-core</artifactId>
            <version>1.2.3</version>
        </dependency>

        <!-- Swagger Annotations (required by generated API interfaces) -->
        <dependency>
            <groupId>io.swagger.core.v3</groupId>
            <artifactId>swagger-annotations</artifactId>
            <version>2.2.25</version>
        </dependency>

        <!-- Validation -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>

        <!-- SpringDoc OpenAPI UI -->
        <dependency>
            <groupId>org.springdoc</groupId>
            <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
            <version>2.8.6</version>
        </dependency>

        <!-- Jackson -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>2.18.2</version>
        </dependency>

        <!-- Lombok (compile-time only) -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- Test -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- OpenAPI Generator -->
            <plugin>
                <groupId>org.openapitools</groupId>
                <artifactId>openapi-generator-maven-plugin</artifactId>
                <version>${openapi-generator.version}</version>
                <executions>
                    <execution>
                        <id>generate-recipes-api</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <inputSpec>${project.basedir}/src/main/resources/openapi/openapi.yaml</inputSpec>
                            <generatorName>spring</generatorName>
                            <output>${project.build.directory}/generated-sources/openapi</output>
                            <apiPackage>com.recipes.api.generated.api</apiPackage>
                            <modelPackage>com.recipes.api.generated.model</modelPackage>
                            <configOptions>
                                <interfaceOnly>true</interfaceOnly>
                                <useSpringBoot3>true</useSpringBoot3>
                                <delegatePattern>false</delegatePattern>
                                <useTags>true</useTags>
                                <useJakartaEe>true</useJakartaEe>
                                <performBeanValidation>true</performBeanValidation>
                                <serializationLibrary>jackson</serializationLibrary>
                                <openApiNullable>false</openApiNullable>
                                <containerDefaultToNull>true</containerDefaultToNull>
                                <additionalModelTypeAnnotations>
                                    @lombok.Builder;
                                    @lombok.NoArgsConstructor;
                                    @lombok.Getter;
                                    @lombok.Setter;
                                    @lombok.EqualsAndHashCode
                                </additionalModelTypeAnnotations>
                            </configOptions>
                            <generateApiTests>false</generateApiTests>
                            <generateModelTests>false</generateModelTests>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Build Helper: add generated sources -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <id>add-generated-sources</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>add-source</goal>
                        </goals>
                        <configuration>
                            <sources>
                                <source>${project.build.directory}/generated-sources/openapi/src/main/java</source>
                            </sources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!--
                Spring Boot Maven Plugin: repackage is disabled because maven-shade-plugin
                below produces the Lambda deployment JAR instead. The ZIP layout used
                previously placed classes under BOOT-INF/classes/, which Lambda's
                classloader cannot find. The shade plugin creates a flat uber JAR with
                all classes at the root, which is what Lambda requires.
            -->
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>repackage</id>
                        <configuration>
                            <skip>true</skip>
                        </configuration>
                    </execution>
                </executions>
                <configuration>
                    <excludes>
                        <exclude>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </exclude>
                    </excludes>
                </configuration>
            </plugin>

            <!--
                Maven Shade Plugin: produces a flat uber JAR for Lambda deployment.
                All classes from the application and its dependencies are merged into
                a single JAR with classes at the root, making them findable by
                Lambda's classloader.

                Key transformers:
                - ServicesResourceTransformer: merges META-INF/services/* files
                  (required for SPI providers like Jackson, Hibernate Validator)
                - AppendingTransformer: merges Spring Boot auto-configuration
                  descriptor files instead of overwriting them — without this,
                  only one module's auto-configurations would be registered.

                Signed JAR entries (*.SF, *.DSA, *.RSA) are excluded to prevent
                SecurityExceptions when the signature no longer matches the merged JAR.
                Lombok is excluded as it is a compile-time only tool.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.5.3</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                            <!--
                                combine.self="override" prevents Maven from positionally
                                merging this list with the parent's (spring-boot-starter-parent
                                defines its own <transformers> list). Without it, parent entry 0
                                — an AppendingTransformer with <resource> — gets merged onto our
                                ServicesResourceTransformer, which has no 'resource' field,
                                causing a PluginConfigurationException at build time.
                            -->
                            <transformers combine.self="override">
                                <!-- Merges META-INF/services/* SPI files across all JARs.
                                     Without this, only one JAR's services file wins, breaking
                                     Jackson, Hibernate Validator, and other SPI-based providers. -->
                                <transformer
                                        implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
                                <!-- Merges Spring Boot auto-configuration descriptors across all JARs.
                                     Without this, only one module's auto-configurations would be registered. -->
                                <transformer
                                        implementation="org.apache.maven.plugins.shade.resource.AppendingTransformer">
                                    <resource>META-INF/spring.factories</resource>
                                </transformer>
                                <transformer
                                        implementation="org.apache.maven.plugins.shade.resource.AppendingTransformer">
                                    <resource>
                                        META-INF/spring/org.springframework.boot.autoconfigure.AutoConfiguration.imports
                                    </resource>
                                </transformer>
                            </transformers>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                    </excludes>
                                </filter>
                                <filter>
                                    <artifact>org.projectlombok:lombok</artifact>
                                    <excludes>
                                        <exclude>**</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <!--
        Local development profile — adds embedded Tomcat so the application can be
        run directly from IntelliJ without deploying to AWS Lambda.

        Why Tomcat is excluded by default:
          The default build targets AWS Lambda, where API Gateway handles HTTP and
          StreamLambdaHandler bridges events to Spring MVC. An embedded web server
          is unnecessary and adds JAR weight, so spring-boot-starter-tomcat is
          excluded from spring-boot-starter-web in the main dependencies.

        How to activate in IntelliJ:
          1. Maven tool window → Profiles → check 'local'
          2. Reload All Maven Projects (circular arrow icon)
          3. Edit Run Configuration → Spring Boot tab → Active profiles → set 'local'
             (this activates application-local.properties, which excludes
             ServerlessAutoConfiguration so Tomcat can start normally)
          4. Run RecipesApplication.main()
          App starts on http://localhost:8080

        Important: do NOT activate this profile when building the Lambda fat JAR.
          Tomcat must not be included in the deployment artifact.
    -->
    <profiles>
        <profile>
            <id>local</id>
            <dependencies>
                <dependency>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-starter-tomcat</artifactId>
                </dependency>
            </dependencies>
        </profile>
    </profiles>

</project>
